  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "../agent-jira/index.ts", "../agent-document/index.ts", "../agent-playwright/index.ts"],
  "exclude": ["node_modules"]
}
