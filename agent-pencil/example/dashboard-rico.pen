{
  "version": "2.10",
  "children": [
    {
      "type": "frame",
      "id": "root",
      "name": "Analytics Dashboard",
      "x": 0, "y": 0, "width": 1600, "height": 980,
      "fill": "#0B1020",
      "layout": "horizontal",
      "children": [
        {
          "type": "frame",
          "id": "sidebar",
          "name": "Sidebar",
          "width": 240,
          "height": "fill_container",
          "fill": "#0F1629",
          "layout": "vertical",
          "padding": [24, 20],
          "gap": 6,
          "children": [
            {
              "type": "frame", "id": "brand", "name": "Brand", "layout": "horizontal", "gap": 10, "alignItems": "center",
              "padding": [0, 0, 24, 0],
              "children": [
                { "type": "frame", "id": "brandLogo", "width": 36, "height": 36, "fill": "#6366F1", "cornerRadius": 10, "layout": "none",
                  "children": [{"type":"icon_font","id":"bL1","x":8,"y":8,"width":20,"height":20,"iconFontName":"zap","iconFontFamily":"lucide","fill":"#FFFFFF"}]},
                { "type": "text", "id": "brandName", "content": "Pencil Analytics", "fill": "#F8FAFC", "fontFamily": "Inter", "fontSize": 16, "fontWeight": "700" }
              ]
            },
            { "type": "text", "id": "navLabel1", "content": "OVERVIEW", "fill": "#64748B", "fontFamily": "Inter", "fontSize": 10, "fontWeight": "600" },
            { "type": "frame", "id": "navHome", "width": "fill_container", "fill": "#1E293B", "cornerRadius": 8, "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iH", "width": 18, "height": 18, "iconFontName": "home", "iconFontFamily": "lucide", "fill": "#A5B4FC" },
                { "type": "text", "id": "tH", "content": "Dashboard", "fill": "#E2E8F0", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "600" }
              ]
            },
            { "type": "frame", "id": "navAnal", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iA", "width": 18, "height": 18, "iconFontName": "zap", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tA", "content": "Analytics", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            },
            { "type": "frame", "id": "navUsers", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iU", "width": 18, "height": 18, "iconFontName": "users", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tU", "content": "Usuarios", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            },
            { "type": "frame", "id": "navMsg", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iM", "width": 18, "height": 18, "iconFontName": "message-square", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tM", "content": "Mensajes", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" },
                { "type": "frame", "id": "msgBadge", "fill": "#EF4444", "cornerRadius": 10, "padding": [2, 8],
                  "children": [{"type":"text","id":"msgBT","content":"12","fill":"#FFFFFF","fontFamily":"Inter","fontSize":10,"fontWeight":"700"}]}
              ]
            },
            { "type": "frame", "id": "spacer1", "height": 24 },
            { "type": "text", "id": "navLabel2", "content": "GESTIÓN", "fill": "#64748B", "fontFamily": "Inter", "fontSize": 10, "fontWeight": "600" },
            { "type": "frame", "id": "navDocs", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iD", "width": 18, "height": 18, "iconFontName": "file-text", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tD", "content": "Documentos", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            },
            { "type": "frame", "id": "navList", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iL", "width": 18, "height": 18, "iconFontName": "list", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tL", "content": "Tareas", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            },
            { "type": "frame", "id": "navShield", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iS", "width": 18, "height": 18, "iconFontName": "shield", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tS", "content": "Seguridad", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            },
            { "type": "frame", "id": "navSettings", "width": "fill_container", "padding": [10, 12], "layout": "horizontal", "gap": 12, "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "iSet", "width": 18, "height": 18, "iconFontName": "settings", "iconFontFamily": "lucide", "fill": "#64748B" },
                { "type": "text", "id": "tSet", "content": "Configuración", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "normal" }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "main",
          "name": "Main",
          "width": "fill_container",
          "height": "fill_container",
          "layout": "vertical",
          "children": [
            {
              "type": "frame", "id": "topbar", "name": "Topbar",
              "width": "fill_container", "height": 64,
              "fill": "#0F1629",
              "layout": "horizontal", "padding": [0, 28], "alignItems": "center", "justifyContent": "space_between",
              "children": [
                { "type": "frame", "id": "searchBox", "width": 360, "height": 38, "fill": "#0B1020", "cornerRadius": 8,
                  "stroke": {"thickness":1,"fill":"#1E293B"},
                  "layout": "horizontal", "padding": [0, 12], "alignItems": "center", "gap": 8,
                  "children": [
                    { "type": "icon_font", "id": "iSearch", "width": 16, "height": 16, "iconFontName": "search", "iconFontFamily": "lucide", "fill": "#64748B" },
                    { "type": "text", "id": "searchPh", "content": "Buscar usuarios, documentos…", "fill": "#64748B", "fontFamily": "Inter", "fontSize": 12, "fontWeight": "normal" }
                  ]
                },
                { "type": "frame", "id": "topActions", "layout": "horizontal", "gap": 14, "alignItems": "center",
                  "children": [
                    { "type": "icon_font", "id": "iBell", "width": 20, "height": 20, "iconFontName": "message-square", "iconFontFamily": "lucide", "fill": "#94A3B8" },
                    { "type": "icon_font", "id": "iSets", "width": 20, "height": 20, "iconFontName": "settings", "iconFontFamily": "lucide", "fill": "#94A3B8" },
                    { "type": "frame", "id": "avatar", "width": 32, "height": 32, "fill": "#10B981", "cornerRadius": 16, "layout":"none",
                      "children":[{"type":"text","id":"avT","x":0,"y":0,"width":32,"height":32,"textAlign":"center","content":"WO","fill":"#FFFFFF","fontFamily":"Inter","fontSize":11,"fontWeight":"700"}]
                    },
                    { "type": "text", "id": "userName", "content": "Walter Omar", "fill": "#E2E8F0", "fontFamily": "Inter", "fontSize": 13, "fontWeight": "600" }
                  ]
                }
              ]
            },
            {
              "type": "frame", "id": "content", "name": "Content",
              "width": "fill_container", "height": "fill_container",
              "layout": "vertical", "padding": [24, 28], "gap": 20,
              "children": [
                {
                  "type": "frame", "id": "pageHeader", "width": "fill_container",
                  "layout": "horizontal", "justifyContent": "space_between", "alignItems": "center",
                  "children": [
                    { "type": "frame", "id": "pgTitle", "layout": "vertical", "gap": 4,
                      "children": [
                        { "type": "text", "id": "pgT", "content": "Resumen general", "fill": "#F8FAFC", "fontFamily": "Inter", "fontSize": 22, "fontWeight": "700" },
                        { "type": "text", "id": "pgS", "content": "Tu actividad y métricas de los últimos 30 días", "fill": "#94A3B8", "fontFamily": "Inter", "fontSize": 12, "fontWeight": "normal" }
                      ]
                    },
                    { "type": "frame", "id": "pgActions", "layout": "horizontal", "gap": 10, "alignItems": "center",
                      "children": [
                        { "type": "frame", "id": "btnRange", "fill": "#1E293B", "cornerRadius": 6, "padding": [8, 14],
                          "stroke":{"thickness":1,"fill":"#334155"},
                          "layout":"horizontal","gap":8,"alignItems":"center",
                          "children":[
                            {"type":"text","id":"brT","content":"Últimos 30 días","fill":"#E2E8F0","fontFamily":"Inter","fontSize":12,"fontWeight":"500"},
                            {"type":"icon_font","id":"brI","width":14,"height":14,"iconFontName":"chevron-down","iconFontFamily":"lucide","fill":"#94A3B8"}
                          ]
                        },
                        { "type": "frame", "id": "btnExport", "fill": "#6366F1", "cornerRadius": 6, "padding": [8, 16],
                          "layout":"horizontal","gap":8,"alignItems":"center",
