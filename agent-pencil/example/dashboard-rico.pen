                            {"type":"icon_font","id":"beI","width":14,"height":14,"iconFontName":"file-text","iconFontFamily":"lucide","fill":"#FFFFFF"},
                            {"type":"text","id":"beT","content":"Exportar","fill":"#FFFFFF","fontFamily":"Inter","fontSize":12,"fontWeight":"600"}
                          ]
                        }
                      ]
                    }
                  ]
