{
  "version": "2.10",
  "children": [
    {
      "type": "frame",
      "id": "root",
      "name": "Login Screen",
      "x": 0,
      "y": 0,
      "width": 800,
      "height": 600,
      "fill": "#0F172A",
      "layout": "vertical",
      "alignItems": "center",
      "justifyContent": "center",
      "children": [
        {
          "type": "frame",
          "id": "card",
          "name": "Login Card",
          "width": 400,
          "fill": "#1E293B",
          "cornerRadius": 12,
          "stroke": { "thickness": 1, "fill": "#334155" },
          "layout": "vertical",
          "padding": [32, 32, 32, 32],
          "gap": 20,
          "children": [
            {
              "type": "frame",
              "id": "logoRow",
              "name": "Logo Row",
              "layout": "horizontal",
              "gap": 10,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "logoBox",
                  "name": "Logo",
                  "width": 40,
                  "height": 40,
                  "fill": "#6366F1",
                  "cornerRadius": 8,
                  "layout": "none",
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "logoIcon",
                      "x": 8,
                      "y": 8,
                      "name": "logoIcon",
                      "width": 24,
                      "height": 24,
                      "iconFontName": "zap",
                      "iconFontFamily": "lucide",
                      "fill": "#FFFFFF"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "brandText",
                  "name": "brandText",
                  "fill": "#F1F5F9",
                  "content": "Pencil Studio",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "text",
              "id": "headline",
              "name": "headline",
              "fill": "#F8FAFC",
              "content": "Inicia sesión",
              "fontFamily": "Inter",
              "fontSize": 26,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "subtext",
              "name": "subtext",
              "fill": "#94A3B8",
              "content": "Ingresa tus credenciales para continuar",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "emailField",
              "name": "emailField",
              "width": "fill_container",
              "height": 44,
              "fill": "#0F172A",
              "cornerRadius": 6,
              "stroke": { "thickness": 1, "fill": "#334155" },
              "layout": "horizontal",
              "alignItems": "center",
              "padding": [0, 14],
              "children": [
                {
                  "type": "text",
                  "id": "emailPlaceholder",
                  "name": "emailPlaceholder",
                  "fill": "#64748B",
                  "content": "correo@ejemplo.com",
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "passwordField",
              "name": "passwordField",
              "width": "fill_container",
              "height": 44,
              "fill": "#0F172A",
              "cornerRadius": 6,
              "stroke": { "thickness": 1, "fill": "#334155" },
              "layout": "horizontal",
              "alignItems": "center",
              "padding": [0, 14],
              "children": [
                {
                  "type": "text",
                  "id": "passwordPlaceholder",
                  "name": "passwordPlaceholder",
                  "fill": "#64748B",
                  "content": "••••••••",
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "submitButton",
              "name": "submitButton",
              "width": "fill_container",
              "height": 44,
              "fill": "#6366F1",
              "cornerRadius": 6,
              "layout": "horizontal",
              "alignItems": "center",
              "justifyContent": "center",
              "children": [
                {
                  "type": "text",
                  "id": "submitText",
                  "name": "submitText",
                  "fill": "#FFFFFF",
                  "content": "Iniciar sesión",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "600"
                }
              ]
            },
            {
              "type": "frame",
              "id": "footerRow",
              "name": "footerRow",
              "width": "fill_container",
              "layout": "horizontal",
              "justifyContent": "center",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "footerQ",
                  "name": "footerQ",
                  "fill": "#94A3B8",
                  "content": "¿No tienes cuenta?",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "footerLink",
                  "name": "footerLink",
                  "fill": "#818CF8",
                  "content": "Crear una",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "600"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
